{
    "rewrites": [
        {
            "source": "/((?!assets|sw\\.js|workbox-.*\\.js|manifest\\.json|favicon\\.ico|.*\\.(png|jpg|jpeg|gif|svg|webp|ico)).*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/assets/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        },
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                }
            ]
        }
    ]
}