{
    "name": "wahat-tour-server",
    "version": "1.0.0",
    "description": "Backend API for Wahat Alrajaa Tour Management System",
    "main": "dist/server.js",
    "type": "module",
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "build": "cd ../client && npm install --include=dev && npm run build && cd ../server && tsc",
        "start": "node dist/server.js",
        "db:migrate": "node dist/scripts/migrate.js"
    },
    "keywords": [
        "tour",
        "management",
        "api"
    ],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "bcrypt": "^5.1.1",
        "cloudinary": "^2.0.1",
        "cookie-parser": "^1.4.6",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "helmet": "^7.1.0",
        "jsonwebtoken": "^9.0.2",
        "multer": "^1.4.5-lts.1",
        "pg": "^8.11.3",
        "zod": "^3.22.4",
        "typescript": "^5.3.3",
        "@types/node": "^20.10.5",
        "@types/bcrypt": "^5.0.2",
        "@types/cookie-parser": "^1.4.6",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.5",
        "@types/multer": "^1.4.11",
        "@types/pg": "^8.15.6"
    },
    "devDependencies": {
        "tsx": "^4.7.0"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}